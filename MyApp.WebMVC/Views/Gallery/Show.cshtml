@model List<MyApp.WebMVC.Views.Gallery.ViewModels.PublicGalleryItemViewModel>
@{
    ViewData["Title"] = "Gallery";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="py-5 bg-light">
    <div class="container">
        <h1 class="text-center display-4 mb-5" data-aos="fade-up">Our Gallery</h1>

        @if (Model.Any())
        {
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up">
                        <a href="@item.ImageUrl" data-lightbox="gallery" data-title="@item.Caption">
                            <img src="@item.ImageUrl" class="img-fluid rounded shadow hover-zoom" alt="@item.Caption">
                        </a>
                        @if (!string.IsNullOrEmpty(item.Caption))
                        {
                            <p class="text-center mt-2 small text-muted">@item.Caption</p>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-center text-muted fs-5">No photos added yet.</p>
        }
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/css/lightbox.min.css">
    <style>
        .hover-zoom {
            transition: transform .4s;
        }

            .hover-zoom:hover {
                transform: scale(1.05);
            }
    </style>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/js/lightbox.min.js"></script>
}