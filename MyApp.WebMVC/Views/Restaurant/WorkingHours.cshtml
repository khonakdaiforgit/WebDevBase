@model MyApp.WebMVC.Views.Restaurant.ViewModels.WorkingHoursViewModel
@{
    ViewData["Title"] = "Working Hours";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Working Hours Management</h1>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="WorkingHours" method="post" class="needs-validation" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="RestaurantId" />

        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-clock"></i> Set Weekly Opening Hours
                </h6>
                <small class="text-muted">All times are in your local timezone</small>
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 18%">Day</th>
                                <th style="width: 24%">Opening Time</th>
                                <th style="width: 24%">Closing Time</th>
                                <th style="width: 16%">Closed?</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var days = new[]
                                {
                                                        ("Sunday",    Model.SundayOpen,    Model.SundayClose),
                                                        ("Monday",    Model.MondayOpen,    Model.MondayClose),
                                                        ("Tuesday",   Model.TuesdayOpen,   Model.TuesdayClose),
                                                        ("Wednesday", Model.WednesdayOpen, Model.WednesdayClose),
                                                        ("Thursday",  Model.ThursdayOpen,  Model.ThursdayClose),
                                                        ("Friday",    Model.FridayOpen,    Model.FridayClose),
                                                        ("Saturday",  Model.SaturdayOpen,  Model.SaturdayClose)
                                                        };

                                foreach (var (day, open, close) in days)
                                {
                                    var openName = $"{day}Open";
                                    var closeName = $"{day}Close";
                                    var isClosed = open == TimeSpan.Zero && close == TimeSpan.Zero;

                                    <tr>
                                        <td class="fw-bold">@day</td>
                                        <td>
                                            <input type="time"
                                                   name="@openName"
                                                   value="@(open == TimeSpan.Zero ? "" : open.Value.ToString(@"hh\:mm"))"
                                                   class="form-control @(isClosed ? "text-muted bg-light" : "")"
                                                   readonly="@isClosed"
                                                   required="!@isClosed" />
                                        </td>
                                        <td>
                                            <input type="time"
                                                   name="@closeName"
                                                   value="@(close == TimeSpan.Zero ? "" : close.Value.ToString(@"hh\:mm"))"
                                                   class="form-control @(isClosed ? "text-muted bg-light" : "")"
                                                   readonly="@isClosed"
                                                   required="!@isClosed" />
                                        </td>
                                        <td class="text-center">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       role="switch"
                                                       @(isClosed ? "checked" : "")
                                                       onchange="toggleClosedDay(this, '@day')">
                                                <!-- این hidden مهم‌ترین بخشه! -->
                                                <input type="hidden" name="@(day)Closed" value="@(isClosed ? "true" : "false")" />
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="alert alert-info mt-4">
                    <i class="fas fa-info-circle"></i>
                    <strong>Tip:</strong> If you mark a day as "Closed", opening and closing times will be ignored.
                </div>
            </div>

            <div class="card-footer text-center bg-light">
                <button type="submit" class="btn btn-lg btn-primary px-5">
                    <i class="fas fa-save"></i> Save All Hours
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // فعال/غیرفعال کردن زمان‌ها وقتی روز بسته باشه
        function toggleClosedDay(checkbox, day) {
            const openInput = document.querySelector(`input[name="${day}Open"]`);
            const closeInput = document.querySelector(`input[name="${day}Close"]`);
            const hiddenClosed = document.querySelector(`input[name="${day}Closed"]`);
            const badge = checkbox.closest('tr').querySelector('.badge');

            if (checkbox.checked) {
                // فقط readonly می‌کنیم — نه disabled!
                openInput.readOnly = true;
                closeInput.readOnly = true;
                openInput.value = "";
                closeInput.value = "";
                hiddenClosed.value = "true";

                //badge.textContent = "Closed";
                //badge.className = "badge bg-danger fs-6";

                openInput.classList.add("text-muted", "bg-light");
                closeInput.classList.add("text-muted", "bg-light");

                openInput.removeAttribute('required');
                closeInput.removeAttribute('required');
            } else {
                openInput.readOnly = false;
                closeInput.readOnly = false;
                openInput.value = openInput.value || "09:00";
                closeInput.value = closeInput.value || "22:00";
                hiddenClosed.value = "false";

                //badge.textContent = "Open";
                //badge.className = "badge bg-success fs-6";

                openInput.classList.remove("text-muted", "bg-light");
                closeInput.classList.remove("text-muted", "bg-light");

                openInput.setAttribute('required', '');
                closeInput.setAttribute('required', '');
            }
        }
        // اعتبارسنجی فرم قبل از ارسال
        (() => {
            'use strict'
            const forms = document.querySelectorAll('.needs-validation')
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>
}