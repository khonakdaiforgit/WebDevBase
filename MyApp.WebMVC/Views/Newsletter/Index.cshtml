@model List<MyApp.WebMVC.Views.Newsletter.ViewModels.NewsletterViewModel>
@{
    ViewData["Title"] = "Newsletter Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Newsletter Management</h1>
        <a asp-action="Create" class="btn btn-sm btn-outline-primary">
            <i class="fas fa-plus"></i> Create Newsletter
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">List of Newsletters</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="newsletterTable" width="100%" cellspacing="0">
                        <thead class="table-light">
                            <tr>
                                <th>Subject</th>
                                <th>Sent At</th>
                                <th>Status</th>
                                <th width="250">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var newsletter in Model.OrderByDescending(n => n.SentAt ?? DateTime.MinValue))
                            {
                                <tr>
                                    <td>
                                        <strong>
                                            <a asp-action="Details" asp-route-id="@newsletter.Id">@newsletter.Subject</a>
                                        </strong>
                                    </td>
                                    <td>
                                        @(newsletter.SentAt?.ToString("MMM dd, yyyy HH:mm") ?? "Not Sent")
                                    </td>
                                    <td>
                                        <span class="badge @(newsletter.Status == NewsletterStatus.Sent ? "bg-success" : (newsletter.Status == NewsletterStatus.Draft ? "bg-warning text-dark" : "bg-secondary"))">
                                            @newsletter.Status
                                        </span>
                                    </td>
                                    <td>
                                        @if (newsletter.Status == NewsletterStatus.Draft)
                                        {
                                            <a asp-action="Edit" asp-route-id="@newsletter.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <form asp-action="SendNow" asp-route-id="@newsletter.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-success" onclick="return confirm('Are you sure you want to send this newsletter now?');">
                                                    <i class="fas fa-paper-plane"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="Delete" asp-route-id="@newsletter.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this newsletter?');">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-envelope fa-5x text-primary mb-3"></i>
            <h4 class="text-muted">No Newsletters Yet</h4>
            <p class="text-muted">Start by creating your first newsletter campaign</p>
            <a asp-action="Create" class="btn btn-primary btn-lg">Create First Newsletter</a>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet" />

    <script>
        $(document).ready(function () {
            $('#newsletterTable').DataTable({
                "order": [[1, "desc"]],
                "pageLength": 25,
                "language": {
                    "search": "Search newsletters:",
                    "lengthMenu": "Show _MENU_ newsletters per page",
                    "info": "Showing _START_ to _END_ of _TOTAL_ newsletters",
                    "paginate": {
                        "previous": "Previous",
                        "next": "Next"
                    }
                }
            });
        });
    </script>
}
