@model List<MyApp.WebMVC.Views.News.ViewModels.NewsViewModel>
@{
    ViewData["Title"] = "News Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">News Management</h1>
        <a asp-action="Create" class="btn btn-sm btn-outline-primary">
            <i class="fas fa-plus"></i> Add News
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">List of News & Events</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="newsTable" width="100%" cellspacing="0">
                        <thead class="table-light">
                            <tr>
                                <th>Title</th>
                                <th>Publish Date</th>
                                <th>Status</th>
                                <th width="250">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var news in Model.OrderByDescending(n => n.PublishDate))
                            {
                                <tr>
                                    <td>
                                        <strong>
                                            <a asp-action="Show" asp-route-id="@news.Id" target="_blank">@news.Title</a>
                                        </strong>
                                    </td>
                                    <td>
                                        @news.PublishDate.ToString("MMM dd, yyyy HH:mm")
                                    </td>
                                    <td>
                                        <span class="badge @(news.IsPublished ? "bg-success" : "bg-warning text-dark")">
                                            @(news.IsPublished ? "Published" : "Draft")
                                        </span>
                                    </td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@news.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-edit"></i>
                                        </a>

                                        <form asp-action="Delete" asp-route-id="@news.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Are you sure you want to delete this news?');">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>

                                        @if (news.IsPublished)
                                        {
                                            <form asp-action="Unpublish" asp-route-id="@news.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                    <i class="fas fa-eye-slash"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Publish" asp-route-id="@news.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-success">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-newspaper fa-5x text-primary mb-3"></i>
            <h4 class="text-muted">No News Yet</h4>
            <p class="text-muted">Start by creating your first news article</p>
            <a asp-action="Create" class="btn btn-primary btn-lg">Create First News</a>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet" />

    <script>
        $(document).ready(function () {
            $('#newsTable').DataTable({
                "order": [[1, "desc"]], 
                "pageLength": 25,
                "language": {
                    "search": "Search news:",
                    "lengthMenu": "Show _MENU_ news per page",
                    "info": "Showing _START_ to _END_ of _TOTAL_ news",
                    "paginate": {
                        "previous": "Previous",
                        "next": "Next"
                    }
                }
            });
        });
    </script>
}