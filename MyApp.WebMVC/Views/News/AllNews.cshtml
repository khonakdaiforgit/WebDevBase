@model MyApp.WebMVC.Views.News.ViewModels.NewsPublicListViewModel
@{
    ViewData["Title"] = "News & Events";
}
<section class="page">
    <div class="container py-5">
        <div class="row">
            <div class="col-12 text-center mb-5">
                <h1 class="display-4 fw-bold text-primary">News & Events</h1>
                <p class="lead text-muted">Stay updated with the latest happenings at our restaurant</p>
            </div>
        </div>

        @if (Model.News.Any())
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model.News)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 hover-shadow">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 200px; object-fit: cover;">
                            }
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title fw-bold">
                                    <a asp-action="Show" asp-route-id="@item.Id" class="text-decoration-none text-dark stretched-link">@item.Title</a>
                                </h5>
                                <small class="text-muted mb-2">
                                    <i class="far fa-calendar-alt me-1"></i>
                                    @item.PublishDate.ToString("MMMM dd, yyyy")
                                </small>
                                <p class="card-text text-muted flex-grow-1">
                                    @Html.Raw(item.Summary)
                                </p>
                                <a asp-action="Show" asp-route-id="@item.Id" class="btn btn-outline-primary mt-3">
                                    Read More <i class="fas fa-arrow-right ms-2"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.Pagination.TotalPages > 1)
            {
                <nav aria-label="News pagination" class="mt-5">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.Pagination.HasPrevious ? "" : "disabled")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.Pagination.CurrentPage - 1)" tabindex="-1">Previous</a>
                        </li>

                        @for (int i = 1; i <= Model.Pagination.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.Pagination.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                            </li>
                        }

                        <li class="page-item @(Model.Pagination.HasNext ? "" : "disabled")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.Pagination.CurrentPage + 1)">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-newspaper fa-5x text-muted mb-4"></i>
                <h3 class="text-muted">No news available yet</h3>
                <p class="text-muted">Check back later for updates!</p>
            </div>
        }
    </div>
</section>
