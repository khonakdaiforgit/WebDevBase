
@model PagedViewModel<MyApp.WebMVC.Models.TransactionViewModel>

@{
    ViewData["Title"] = "Transactions";
    Layout = "~/Views/Shared/_DashLayout.cshtml";

    var fileLink = ViewBag.fileLink as FileLinkViewModel;
}

<h2>Order Transactions</h2>
<p>
    <span class="text-black-50">Product ID:</span> @fileLink.Id 
    <span class="text-black-50">Product Description:</span> @fileLink.FileDescription
</p>
<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Seller Wallet</th>
            <th>Price</th>
            <th>Timestamp</th>
            <th>Status</th>
            <th>Payout Status</th>
            <th>Pay Time</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.SellerWallet</td>
                <td>@item.Price.ToString("N2")</td>
                <td>@item.Timestamp.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</td>
                <td>@item.Status</td>
                <td>@item.PayoutStatus</td>
                <td>@(item.PayTime?.ToLocalTime().ToString("yyyy/MM/dd HH:mm") ?? "-")</td>
            </tr>
        }
    </tbody>
</table>

<!-- Paging Controls -->
<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center">

        <!-- First -->
        @if (Model.PageIndex > 1)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-action="ProductTransaction"
                   asp-route-fileLinkId="@fileLink.Id"
                   asp-route-page="1"
                   asp-route-pageSize="@Model.PageSize">First</a>
            </li>
        }
        else
        {
            <li class="page-item disabled"><span class="page-link">First</span></li>
        }

        <!-- Previous -->
        @if (Model.HasPreviousPage)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-action="ProductTransaction"
                   asp-route-fileLinkId="@fileLink.Id"
                   asp-route-page="@(Model.PageIndex - 1)"
                   asp-route-pageSize="@Model.PageSize">Previous</a>
            </li>
        }
        else
        {
            <li class="page-item disabled"><span class="page-link">Previous</span></li>
        }

        <!-- Page Numbers -->
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            if (i == Model.PageIndex)
            {
                <li class="page-item active"><span class="page-link">@i</span></li>
            }
            else
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-action="ProductTransaction"
                       asp-route-fileLinkId="@fileLink.Id"
                       asp-route-page="@i"
                       asp-route-pageSize="@Model.PageSize">@i</a>
                </li>
            }
        }

        <!-- Next -->
        @if (Model.HasNextPage)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-action="ProductTransaction"
                   asp-route-fileLinkId="@fileLink.Id"
                   asp-route-page="@(Model.PageIndex + 1)"
                   asp-route-pageSize="@Model.PageSize">Next</a>
            </li>
        }
        else
        {
            <li class="page-item disabled"><span class="page-link">Next</span></li>
        }

        <!-- Last -->
        @if (Model.PageIndex < Model.TotalPages)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-action="ProductTransaction"
                   asp-route-fileLinkId="@fileLink.Id"
                   asp-route-page="@Model.TotalPages"
                   asp-route-pageSize="@Model.PageSize">Last</a>
            </li>
        }
        else
        {
            <li class="page-item disabled"><span class="page-link">Last</span></li>
        }

    </ul>
</nav>
