@model List<MyApp.WebMVC.Models.FileLinkViewModel>

@{
    ViewData["Title"] = "Your Products";
    Layout = "~/Views/Shared/_DashLayout.cshtml";
}

<!-- Header Section -->
    <h1 class="mb-3" data-aos="fade-up">Your Products</h1>
    <p class="text-muted">Manage your file sales links below. Share them to earn USDT instantly with only a 2% fee.</p>
    <a class="btn btn-primary mb-3" asp-action="NewProduct" role="button"><i class="fas fa-plus me-2"></i>New Product</a>
    <hr />

    <!-- Success/Error Message -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Filter and Search -->
    <div class="mb-3">
        <div class="input-group w-50">
            <input type="text" class="form-control" placeholder="Search by URL or status" id="searchInput">
            <button class="btn btn-outline-secondary" type="button"><i class="fas fa-search"></i></button>
        </div>
    </div>

    <!-- Product Table -->
    <div class="table-responsive" data-aos="fade-up">
        <table class="table table-striped table-hover" id="productTable">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Sales page</th>
                    <th scope="col">Product Description</th>
                    <th scope="col">File URL</th>
                    <th scope="col">Price</th>
                    <th scope="col">Status</th>
                    <th scope="col">Created</th>
                    <th scope="col">Sales Count</th>
                    <th scope="col" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.UniqueCode</td>
                        <td>
                            <a href="/@item.UniqueCode" class="btn btn-sm btn-outline-primary" target="_blank">View Page</a>
                            <button class="btn btn-sm btn-outline-secondary ms-1 copy-btn-page"
                                    data-clipboard-text="@($"{Context.Request.Scheme}://{Context.Request.Host}/{item.UniqueCode}")"
                                    title="Copy page url to clipboard">
                                <i class="fas fa-copy"></i>
                            </button>
                        </td>
                        <td>@item.FileDescription</td>
                        <td>
                            <a href="@item.Url" target="_blank" class="text-primary">@* <i class="fas fa-link me-2"></i> *@Open Link</a>
                            @* <button class="btn btn-sm btn-outline-secondary ms-2 copy-btn-url" data-clipboard-text="@item.Url" title="Copy file url to clipboard"><i class="fas fa-copy"></i></button> *@
                        </td>
                        <td>$@item.Price.ToString("N2")</td>
                        <td>
                            <span class="badge @(item.StatusDisplay == "Active" ? "bg-success" : "bg-warning")">@item.StatusDisplay</span>
                        </td>
                        <td>@item.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                        <td>@item.SellsCount</td>
                        <td class="text-center">
                          

                            <a asp-action="ProductTransaction" asp-route-fileLinkId="@item.Id" class="btn btn-primary btn-sm">Order Transaction</a>

                            <a asp-action="EditProduct" asp-route-fileLinkId="@item.Id" class="btn btn-primary btn-sm">Edit</a>

                            @if (item.StatusDisplay != "Active")
                            {
                                <form asp-action="ActivateProduct" asp-route-fileLinkId="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-success">Activate</button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="DeactivateProduct" asp-route-fileLinkId="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-warning">Deactivate</button>
                                </form>
                            }
                            <form asp-action="DeleteProduct" asp-route-fileLinkId="@item.Id" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this product?');"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Security Note -->
    <div class="alert alert-info mt-4" role="alert">
        <i class="fas fa-lock me-2"></i> Your file links are secure, and we never access or store file contents. Questions? <a href="mailto:cryptofile.runasp.net@outlook.com">Contact Support</a>.
    </div>


@section Scripts {
    <!-- AOS for animations -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <!-- Clipboard.js for copy-to-clipboard -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/clipboard.js/2.0.10/clipboard.min.js"></script>
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <script>
        AOS.init();

        // Initialize Clipboard.js
        var clipboard_file = new ClipboardJS('.copy-btn-url');
        clipboard_file.on('success', function (e) {
            alert('Url copied to clipboard!');
            e.clearSelection();
        });
        clipboard_file.on('error', function (e) {
            alert('Failed to copy url.');
        });

        var clipboard_page = new ClipboardJS('.copy-btn-page');
        clipboard_page.on('success', function (e) {
            alert('Page copied to clipboard!');
            e.clearSelection();
        });
        clipboard_page.on('error', function (e) {
            alert('Failed to copy page.');
        });

        // Simple table search
        document.getElementById('searchInput').addEventListener('keyup', function () {
            var input = this.value.toLowerCase();
            var rows = document.querySelectorAll('#productTable tbody tr');
            rows.forEach(row => {
                var url = row.cells[0].textContent.toLowerCase();
                var status = row.cells[2].textContent.toLowerCase();
                row.style.display = (url.includes(input) || status.includes(input)) ? '' : 'none';
            });
        });
    </script>
}