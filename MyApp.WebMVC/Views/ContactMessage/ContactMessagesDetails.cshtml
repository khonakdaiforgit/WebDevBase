@model MyApp.WebMVC.Models.ContactMessageViewModel

@{
    ViewData["Title"] = "Message Details";
    Layout = "~/Views/Shared/_DashLayout.cshtml";
}


    <h1 class="mb-3" data-aos="fade-up">Message Details</h1>
    <p class="text-muted">Details of the contact message.</p>

    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" data-aos="fade-up">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" data-aos="fade-up">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Message Details -->
    <div class="card" data-aos="fade-up">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Report Number</dt>
                <dd class="col-sm-9">@Model.ReportNumber</dd>
                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>
                <dt class="col-sm-3">Subject</dt>
                <dd class="col-sm-9">@Model.Subject</dd>
                <dt class="col-sm-3">Message</dt>
                <dd class="col-sm-9">@Model.Message</dd>
                <dt class="col-sm-3">Date</dt>
                <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @if (Model.IsRead)
                    {
                        <span class="badge bg-success">Read</span>
                    }
                    else
                    {
                        <span class="badge bg-warning">Unread</span>
                    }
                </dd>
            </dl>
            <a asp-action="UserContactMessages" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back to List</a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this message?');">
                <button type="submit" class="btn btn-outline-danger"><i class="fas fa-trash me-1"></i>Delete</button>
            </form>
        </div>
    </div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <script>
        AOS.init();
    </script>
}