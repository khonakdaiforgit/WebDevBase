@model MyApp.WebMVC.Models.ContactMessageListViewModel

@{
    ViewData["Title"] = "Contact Messages";
    Layout = "~/Views/Shared/_DashLayout.cshtml";
}

<h1 class="mb-3" data-aos="fade-up">Contact Messages</h1>
<p class="text-muted">Manage user contact messages.</p>

<!-- Success/Error Messages -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" data-aos="fade-up">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert" data-aos="fade-up">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Filter -->
<form asp-action="UserContactMessages" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-3">
            <div class="form-check">
                <input type="checkbox" class="form-check-input" id="onlyUnread" name="onlyUnread" value="true" @(Model.OnlyUnread ? "checked" : "")>
                <label class="form-check-label" for="onlyUnread">Show only unread messages</label>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary"><i class="fas fa-filter me-2"></i>Apply Filter</button>
        </div>
    </div>
</form>

<!-- Messages Table -->
<div class="card">
    <div class="card-body">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th scope="col">Report Number</th>
                    <th scope="col">Email</th>
                    <th scope="col">Subject</th>
                    <th scope="col">Date</th>
                    <th scope="col">Status</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var message in Model.Messages)
                {
                    <tr>
                        <td>@message.ReportNumber</td>
                        <td>@message.Email</td>
                        <td>@message.Subject</td>
                        <td>@message.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (message.IsRead)
                            {
                                <span class="badge bg-success">Read</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Unread</span>
                            }
                        </td>
                        <td>
                            <a asp-action="ContactMessagesDetails" asp-route-id="@message.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye me-1"></i>View</a>
                        @*     <form asp-action="Delete" asp-route-id="@message.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this message?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash me-1"></i>Delete</button>
                            </form> *@
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


<!-- Pagination -->
@{
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
    var maxPagesToShow = 5;
    var startPage = Math.Max(1, Model.PageNumber - maxPagesToShow / 2);
    var endPage = Math.Min(totalPages, startPage + maxPagesToShow - 1);
    startPage = Math.Max(1, endPage - maxPagesToShow + 1);
}
@if (totalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-3">
        <ul class="pagination justify-content-center">
            <!-- First -->
            <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="UserContactMessages" asp-route-pageNumber="1" asp-route-pageSize="@Model.PageSize" asp-route-onlyUnread="@Model.OnlyUnread">
                    <i class="fas fa-angle-double-left"></i> First
                </a>
            </li>
            <!-- Previous -->
            <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="UserContactMessages" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-pageSize="@Model.PageSize" asp-route-onlyUnread="@Model.OnlyUnread">
                    <i class="fas fa-angle-left"></i> Previous
                </a>
            </li>
            <!-- Page Numbers -->
            @for (var i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="UserContactMessages" asp-route-pageNumber="@i" asp-route-pageSize="@Model.PageSize" asp-route-onlyUnread="@Model.OnlyUnread">@i</a>
                </li>
            }
            <!-- Next -->
            <li class="page-item @(Model.PageNumber == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="UserContactMessages" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-pageSize="@Model.PageSize" asp-route-onlyUnread="@Model.OnlyUnread">
                    Next <i class="fas fa-angle-right"></i>
                </a>
            </li>
            <!-- Last -->
            <li class="page-item @(Model.PageNumber == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="UserContactMessages" asp-route-pageNumber="@totalPages" asp-route-pageSize="@Model.PageSize" asp-route-onlyUnread="@Model.OnlyUnread">
                    Last <i class="fas fa-angle-double-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}


