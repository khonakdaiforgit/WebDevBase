@model MyApp.Application.DTOs.LogFilterDto
@{
    ViewData["Title"] = "Dashboard - Logs";
    Layout = "~/Views/Shared/_DashLayout.cshtml";

    var pagedResult = ViewBag.PagedResult as MyApp.Application.DTOs.PagedLogResultDto ?? new MyApp.Application.DTOs.PagedLogResultDto();
    var error = ViewBag.Error as string;
}

<h1 class="mb-4">Logs Dashboard</h1>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}

<!-- فرم فیلتر -->
<form asp-action="Logs" method="post" class="mb-4">
    <div class="row">
        <div class="col-md-3">
            <label class="form-label">User ID</label>
            <input type="text" class="form-control" asp-for="UserId" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Level</label>
            <select class="form-control" asp-for="Level">
                <option value="">All</option>
                <option value="Info">Info</option>
                <option value="Warning">Warning</option>
                <option value="Error">Error</option>
                <option value="Critical">Critical</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Project</label>
            <select class="form-control" asp-for="Project">
                <option value="">All</option>
                <option value="MVC">MVC</option>
                <option value="API">API</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Search</label>
            <input type="text" class="form-control" asp-for="SearchTerm" placeholder="Search in Path or Message" />
        </div>
    </div>
    <div class="row mt-3">
        <div class="col-md-3">
            <label class="form-label">Start Date</label>
            <input type="date" class="form-control" asp-for="StartDate" />
        </div>
        <div class="col-md-3">
            <label class="form-label">End Date</label>
            <input type="date" class="form-control" asp-for="EndDate" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Page Size</label>
            <select class="form-control" asp-for="PageSize">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>
        <div class="col-md-3 align-self-end">
            <input type="hidden" asp-for="PageNumber" value="1" />
            <button type="submit" class="btn btn-primary">Filter</button>
        </div>
    </div>
</form>

<!-- جدول لاگ‌ها -->
<table id="logsTable" class="table table-striped">
    <thead>
        <tr>
            <th>Timestamp</th>
            <th>Path</th>
            <th>Source</th>
            <th>Method</th>
            <th>Status</th>
            <th>Level</th>
            <th>Message</th>
            <th>User ID</th>
            <th>Hashed IP</th>
            <th>Project</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in pagedResult.Logs)
        {
            <tr>
                <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>@log.Path</td>
                <td>@log.Source</td>
                <td>@log.Method</td>
                <td>@log.StatusCode</td>
                <td>@log.Level</td>
                <td>@log.Message</td>
                <td>@log.UserId</td>
                <td>@log.HashedIp</td>
                <td>@log.Project</td>
                <td>
                    @if (!string.IsNullOrEmpty(log.ExceptionMessage))
                    {
                        <button class="btn btn-sm btn-info" data-bs-toggle="modal" data-bs-target="#detailsModal_@log.Id">View Details</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- کنترل‌های صفحه‌بندی -->
<nav aria-label="Logs pagination">
    <ul class="pagination justify-content-center">
        <li class="page-item @(pagedResult.PageNumber <= 1 ? "disabled" : "")">
            <a class="page-link" href="@Url.Action("Logs", new { UserId = Model.UserId, Level = Model.Level, Project = Model.Project, SearchTerm = Model.SearchTerm, StartDate = Model.StartDate?.ToString("yyyy-MM-dd"), EndDate = Model.EndDate?.ToString("yyyy-MM-dd"), PageNumber = 1, PageSize = Model.PageSize })">First</a>
        </li>
        <li class="page-item @(pagedResult.PageNumber <= 1 ? "disabled" : "")">
            <a class="page-link" href="@Url.Action("Logs", new { UserId = Model.UserId, Level = Model.Level, Project = Model.Project, SearchTerm = Model.SearchTerm, StartDate = Model.StartDate?.ToString("yyyy-MM-dd"), EndDate = Model.EndDate?.ToString("yyyy-MM-dd"), PageNumber = pagedResult.PageNumber - 1, PageSize = Model.PageSize })">Previous</a>
        </li>
        @for (var i = Math.Max(1, pagedResult.PageNumber - 2); i <= Math.Min(pagedResult.TotalPages, pagedResult.PageNumber + 2); i++)
        {
            <li class="page-item @(i == pagedResult.PageNumber ? "active" : "")">
                <a class="page-link" href="@Url.Action("Logs", new { UserId = Model.UserId, Level = Model.Level, Project = Model.Project, SearchTerm = Model.SearchTerm, StartDate = Model.StartDate?.ToString("yyyy-MM-dd"), EndDate = Model.EndDate?.ToString("yyyy-MM-dd"), PageNumber = i, PageSize = Model.PageSize })">@i</a>
            </li>
        }
        <li class="page-item @(pagedResult.PageNumber >= pagedResult.TotalPages ? "disabled" : "")">
            <a class="page-link" href="@Url.Action("Logs", new { UserId = Model.UserId, Level = Model.Level, Project = Model.Project, SearchTerm = Model.SearchTerm, StartDate = Model.StartDate?.ToString("yyyy-MM-dd"), EndDate = Model.EndDate?.ToString("yyyy-MM-dd"), PageNumber = pagedResult.PageNumber + 1, PageSize = Model.PageSize })">Next</a>
        </li>
        <li class="page-item @(pagedResult.PageNumber >= pagedResult.TotalPages ? "disabled" : "")">
            <a class="page-link" href="@Url.Action("Logs", new { UserId = Model.UserId, Level = Model.Level, Project = Model.Project, SearchTerm = Model.SearchTerm, StartDate = Model.StartDate?.ToString("yyyy-MM-dd"), EndDate = Model.EndDate?.ToString("yyyy-MM-dd"), PageNumber = pagedResult.TotalPages, PageSize = Model.PageSize })">Last</a>
        </li>
    </ul>
    <div class="text-center">
        Page @pagedResult.PageNumber of @pagedResult.TotalPages (Total Logs: @pagedResult.TotalCount)
    </div>
</nav>


<!-- Modal برای جزئیات خطا -->
@foreach (var log in pagedResult.Logs)
{
    if (!string.IsNullOrEmpty(log.ExceptionMessage))
    {
        <div class="modal fade" id="detailsModal_@log.Id" tabindex="-1" aria-labelledby="detailsModalLabel_@log.Id" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="detailsModalLabel_@log.Id">Log Details</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p><strong>Timestamp:</strong> @log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</p>
                        <p><strong>Level:</strong> @log.Level</p>
                        <p><strong>Message:</strong> @log.Message</p>
                        <p><strong>Exception:</strong> @log.ExceptionMessage</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
}