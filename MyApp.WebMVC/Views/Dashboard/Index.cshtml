@model MyApp.Application.DTOs.LogFilterDto
@{
    Layout = "~/Views/Shared/_DashLayout.cshtml";


    ViewData["Title"] = "Dashboard Stats";

    var stats = ViewBag.Stats as MyApp.WebMVC.Models.LogStatsViewModel ?? new MyApp.WebMVC.Models.LogStatsViewModel();
    var error = ViewBag.Error as string;
}

    <h1 class="mb-4">Statistics Dashboard</h1>

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger">@error</div>
    }
    <!-- فرم فیلتر -->
    <form asp-action="Index" method="post" class="mb-4">
        <div class="row">
            <div class="col-md-3">
                <label class="form-label">Start Date</label>
                <input type="date" class="form-control" asp-for="StartDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label">End Date</label>
                <input type="date" class="form-control" asp-for="EndDate" />
            </div>
            <div class="col-md-3 align-self-end">
                <button type="submit" class="btn btn-primary">Filter</button>
            </div>
        </div>
    </form>

    <!-- داشبورد آمار -->
    <div class="row">
        <div class="col-md-12">
            <canvas id="statsChart" height="200"></canvas>
        </div>
    </div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const stats = @Html.Raw(Json.Serialize(stats));

        const labels = Object.keys(stats.visitsByDay); // تاریخ‌ها مرتب‌شده

        const data = {
            labels: labels,
            datasets: [
                {
                    label: 'Visits',
                    data: labels.map(date => stats.visitsByDay[date] || 0),
                    borderColor: 'rgb(75, 192, 192)',
                    tension: 0.1
                },
                {
                    label: 'Registrations',
                    data: labels.map(date => stats.registrationsByDay[date] || 0),
                    borderColor: 'rgb(54, 162, 235)',
                    tension: 0.1
                },
                {
                    label: 'File Sale Views',
                    data: labels.map(date => stats.fileSaleViewsByDay[date] || 0),
                    borderColor: 'rgb(255, 206, 86)',
                    tension: 0.1
                },
                {
                    label: 'Successful Sales',
                    data: labels.map(date => stats.successfulSalesByDay[date] || 0),
                    borderColor: 'rgb(153, 102, 255)',
                    tension: 0.1
                }
            ]
        };

        const config = {
            type: 'line',
            data: data,
            options: {
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        };

        const ctx = document.getElementById('statsChart').getContext('2d');
        new Chart(ctx, config);
    </script>
}