@using MyApp.WebMVC.Views.Home.ViewModels
@model MyApp.WebMVC.Views.Home.ViewModels.ContactViewModel
@{
    var restaurantInfo = ViewBag.rsturantInfo as HomeIndexViewModel;

    ViewData["Title"] = "Contact Us - " + restaurantInfo.RestaurantName;
}

<div class="container py-5 page">
    <div class="row">
        <!-- اطلاعات تماس -->
        <div class="col-lg-5 mb-5">
            <h1 class="mb-4">Get in Touch</h1>
            <p class="lead">We'd love to hear from you! Whether you have a question, feedback, or just want to say hi.</p>

            <div class="mt-5">
                <h5><i class="bi bi-geo-alt-fill text-primary"></i> Address</h5>
                <p>@restaurantInfo.Address</p>

                <h5 class="mt-4"><i class="bi bi-telephone-fill text-primary"></i> Phone</h5>
                <p><a href="tel:@restaurantInfo.Phone">@restaurantInfo.Phone</a></p>

                <h5 class="mt-4"><i class="bi bi-envelope-fill text-primary"></i> Email</h5>
                <p><a href="mailto:@Model.Email">@Model.Email</a></p>
            </div>
        </div>

        <!-- فرم تماس -->
        <div class="col-lg-7">
            @if (TempData["ContactSuccess"] is string success)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <strong>Success!</strong> @success
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ContactError"] is string error)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <strong>Error!</strong> @error
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow-sm">
                <div class="card-body p-5">
                    <h3 class="card-title mb-4">Send us a Message</h3>

                    <form asp-action="Contact" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Your Name</label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="John Doe" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email Address</label>
                            <input asp-for="Email" class="form-control form-control-lg" placeholder="john@example.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Message" class="form-label">Your Message</label>
                            <textarea asp-for="Message" class="form-control" rows="6" placeholder="Hi there! I wanted to ask about..."></textarea>
                            <span asp-validation-for="Message" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg px-5">
                            <i class="bi bi-send"></i> Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}