@using MyApp.WebMVC.Views.Shared.ViewModels
@using MyApp.WebMVC.Views.Home.ViewModels

@model ContactViewModel

@{
    var layoutData = ViewData["LayoutData"] as SharedLayoutViewModel
                    ?? new SharedLayoutViewModel();

    ViewData["Title"] = "Contact Us";
}


<section class="page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <!-- هدر مینیمال -->
                <div class="text-center mb-5">
                    <h1 class="display-5 fw-light">Contact Us</h1>
                    <p class="lead text-muted mt-3">We’re here for you. Reservations, inquiries, or just to say hello.</p>
                </div>

                <!-- پیام موفقیت یا خطا -->
                @if (TempData["ContactSuccess"] is string success)
                {
                    <div class="alert alert-success-soft text-center mb-5 py-4 rounded-4">
                        <i class="fas fa-check me-2"></i> @success
                    </div>
                }
                @if (TempData["ContactError"] is string error)
                {
                    <div class="alert alert-danger-soft text-center mb-5 py-4 rounded-4">
                        <i class="fas fa-exclamation-triangle me-2"></i> @error
                    </div>
                }

                <!-- فرم مینیمال و شیک -->
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-body p-5 p-lg-6">
                        <form asp-action="Contact" method="post" class="row g-5">
                            @Html.AntiForgeryToken()

                            <div class="col-md-6">
                                <label class="form-label fw-medium text-dark">Name</label>
                                <input asp-for="Name" class="form-control form-control-lg border-0 border-bottom rounded-0 px-0 shadow-none fs-5"
                                       placeholder="Your name" style="border-bottom: 2px solid #e9ecef;" />
                                <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-medium text-dark">Email</label>
                                <input asp-for="Email" type="email" class="form-control form-control-lg border-0 border-bottom rounded-0 px-0 shadow-none fs-5"
                                       placeholder="your@email.com" style="border-bottom: 2px solid #e9ecef;" />
                                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-medium text-dark">Message</label>
                                <textarea asp-for="Message" rows="7" class="form-control border-0 border-bottom rounded-0 px-0 shadow-none fs-5"
                                          placeholder="How can we help you today?" style="border-bottom: 2px solid #e9ecef; resize: none;"></textarea>
                                <span asp-validation-for="Message" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-12 text-end">
                                <button type="submit" class="btn btn-dark px-5 py-3 shadow-sm text-white">
                                    Send Message
                                    <i class="fas fa-arrow-right ms-2"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- اطلاعات تماس پایین فرم (اختیاری - خیلی تمیز) -->
                <div class="row mt-6 g-5 text-center text-lg-start mt-3">
                    <div class="col-md-4">
                        <p class="text-muted small text-uppercase tracking-wider mb-2">Address</p>
                        <p class="fw-medium">@layoutData.FullAddress</p>
                    </div>
                    <div class="col-md-4">
                        <p class="text-muted small text-uppercase tracking-wider mb-2">Phone</p>
                        <p><a href="tel:@layoutData.Phone.Replace(" ", "")" class="text-dark text-decoration-none fw-medium">@layoutData.Phone</a></p>
                    </div>
                    <div class="col-md-4">
                        <p class="text-muted small text-uppercase tracking-wider mb-2">Hours Today</p>
                        <p class="fw-medium">
                            @layoutData.TodayHoursDisplay
                            @if (layoutData.IsOpenNow)
                            {
                                <span class="text-success ms-2">● Open</span>
                            }
                            else
                            {
                                <span class="text-muted ms-2">● Closed</span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="container-fluid px-0">
    <!-- نقشه بزرگ تمام‌عرض -->
    @if (layoutData.Latitude != 0 && layoutData.Longitude != 0)
    {

        <iframe width="100%"
                height="500vh"
                frameborder="0"
                style="border:0;"
                allowfullscreen
                src="https://www.google.com/maps?q=@layoutData.Latitude,@layoutData.Longitude&hl=en&z=16&output=embed">
        </iframe>
    }
    else
    {
        <div class="alert alert-info text-center py-5 mb-5">
            <i class="fas fa-map-marked-alt fa-3x mb-3"></i>
            <p class="lead">Location map will be displayed here once coordinates are configured.</p>
        </div>
    }
</div>
@section Styles {
    <style>
        .border-bottom:focus {
            border-bottom: 2px solid #000 !important;
            box-shadow: none;
        }

        .alert-success-soft {
            background-color: rgba(34, 197, 94, 0.1);
            border: 1px solid rgba(34, 197, 94, 0.2);
            color: #166534;
        }

        .alert-danger-soft {
            background-color: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #991b1b;
        }

        .card {
            background: #fdfdfd;
        }

        .tracking-wider {
            letter-spacing: 0.1em;
        }
    </style>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}