@using MyApp.Application.Helper
@{
    ViewData["Title"] = "Affiliate Program";
}
<style>
    .header-card {
        background: linear-gradient(135deg, #2c3e50, #3498db);
        color: white;
        border-radius: 15px;
        padding: 2rem;
    }

    .section-card {
        background-color: white;
        border-radius: 10px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        padding: 20px;
        margin-bottom: 20px;
    }

        .section-card h2 {
            color: #2c3e50;
            border-bottom: 2px solid #3498db;
            padding-bottom: 10px;
        }

    .list-custom {
        padding-left: 20px;
    }

        .list-custom li {
            margin-bottom: 10px;
        }

    .highlight-box {
        background-color: #e9f7ef;
        border-left: 4px solid #27ae60;
        padding: 15px;
        border-radius: 5px;
        margin: 15px 0;
    }

    .footer-text {
        font-size: 0.9rem;
    }
</style>

<!-- Main Content -->
<div class="container py-5">
    <div class="header-card mb-5">
        <h1 class="text-center mb-4"><i class="fas fa-users-cog"></i> Affiliate Program</h1>
        <p class="lead text-center">
            Earn passive income by inviting others to sell files anonymously on CryptoFile.
            Get a share of the platform fee on every sale made through your network – forever!
        </p>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-gift"></i> 1. How Much Can You Earn?</h2>
        <p>
            The platform charges a flat <strong>2% fee</strong> on every successful sale.
            As an affiliate, you receive <strong>50% of this fee</strong> (i.e., <strong>1% of total sales</strong>)
            from every transaction made by users who signed up via your referral link.
        </p>
        <div class="highlight-box">
            <strong>Example:</strong> If your referrals generate 10,000 USDT in total sales:<br>
            → Platform fee = 200 USDT<br>
            → <strong>Your commission = 100 USDT</strong> (paid instantly in USDT)
        </div>
        <p>No caps. No tiers. Lifetime earnings on all referred users.</p>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-link"></i> 2. How It Works</h2>
        <ol class="list-custom">
            <li><strong>Get Your Unique Link</strong> – After signing up, generate your personal referral link from the dashboard.</li>
            <li><strong>Share Anywhere</strong> – Post on social media, forums, Telegram, Discord, or embed in content.</li>
            <li><strong>Earn Automatically</strong> – When someone registers and sells using your link, you earn on every sale they make.</li>
            <li><strong>Track & Withdraw</strong> – View real-time stats and withdraw earnings anytime (minimum @AppSettingsHelper.MinimumPayoutAmount USDT).</li>
        </ol>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-chart-line"></i> 3. Real-Time Dashboard</h2>
        <p>Inside your private dashboard, you’ll see:</p>
        <ul class="list-custom">
            <li><i class="fas fa-users"></i> Number of users who registered via your link</li>
            <li><i class="fas fa-box"></i> Total products listed by your network</li>
            <li><i class="fas fa-shopping-cart"></i> Total sales transactions</li>
            <li><i class="fas fa-dollar-sign"></i> Total sales volume in USDT</li>
            <li><i class="fas fa-wallet"></i> Your payable commission + withdrawal button</li>
        </ul>
        <p>All data is encrypted and visible only to you.</p>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-handshake"></i> 4. Payouts</h2>
        <p>
            Commissions are calculated in real-time and added to your affiliate balance after each sale.
            You can request a payout to your USDT wallet anytime once you reach
            <strong>@AppSettingsHelper.MinimumPayoutAmount USDT</strong>.
        </p>
        <ul class="list-custom">
            <li><i class="fas fa-bolt"></i> Instant processing via TRC20</li>
            <li><i class="fas fa-shield-alt"></i> No hidden fees – only network gas</li>
            <li><i class="fas fa-history"></i> Full payout history in dashboard</li>
        </ul>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-user-shield"></i> 5. Privacy & Security</h2>
        <p>
            We never ask for personal information. Your referral link contains only an anonymous code.
            All affiliate data is encrypted and stored securely.
            We do not share your earnings or activity with anyone.
        </p>
        <p>
            <strong>You remain fully anonymous</strong> – just like every seller on CryptoFile.
        </p>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-gavel"></i> 6. Rules & Responsibility</h2>
        <p>
            <strong>You are responsible for legal promotion.</strong> Do not spam, mislead, or promote illegal content.
            We reserve the right to suspend affiliate accounts that violate platform rules.
        </p>
        <p>
            CryptoFile only manages links and payments – we never host or review files.
            All content responsibility lies with the seller.
        </p>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-headset"></i> 7. Ready to Start Earning?</h2>
        <div class="text-center mt-4">
            <a asp-controller="Account" asp-action="Register" class="btn btn-success btn-lg px-5 py-3">
                <i class="fas fa-user-plus me-2"></i> Sign Up Now & Get Your Link
            </a>
        </div>
        <p class="text-center mt-3 text-muted">
            Already have an account?
            <a asp-controller="Account" asp-action="Login">Log in</a> and go to your
            <strong>Affiliate Dashboard</strong> to activate your link.
        </p>
    </div>

    <div class="text-center footer-text mt-5">
        <p class="text-muted">
            Last updated: @DateTimeOffset.Parse("11/1/2025 14:20 PM").ToString("MMMM dd, yyyy, hh:mm tt") UTC
        </p>
    </div>
</div>