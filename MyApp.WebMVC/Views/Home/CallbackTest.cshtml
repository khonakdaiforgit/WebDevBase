@{
    ViewData["Title"] = "Test Callback";
}

<h2>Test Callback</h2>

<form id="callbackForm">
    <label>Order ID:</label>
    <input type="text" name="order_id" value="ORDER-123e4567-e89b-12d3-a456-426614174000" /><br />

    <label>Payment Status:</label>
    <input type="text" name="payment_status" value="finished" /><br />

    <!-- می‌تونی سایر فیلدها رو هم اضافه کنی یا فقط لازم‌ترین‌ها رو استفاده کنی -->

    <button type="submit">Send Callback</button>
</form>

<div id="result"></div>

<script>
    document.getElementById('callbackForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        const formData = new FormData(e.target);
        const json = {};

        formData.forEach((value, key) => {
            json[key] = value;
        });

        const response = await fetch('/Home/callback', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(json)
        });

        const result = await response.text();
        document.getElementById('result').innerText = result;
    });
</script>
