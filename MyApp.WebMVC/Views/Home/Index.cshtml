@model MyApp.WebMVC.Views.Home.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero d-flex align-items-center text-center">
    <div class="container position-relative">
        <h1 class="display-3 fw-bold mb-3">@Model.RestaurantName</h1>
        <p class="lead fs-3 mb-4">Modern Cuisine • Cozy Ambience • Unforgettable Taste</p>

        <div class="mb-5">
            <span class="badge fs-5 px-5 py-3 shadow-lg" style="font-weight:normal">
                <i class="fas fa-circle fa-beat-fade me-2"></i>
                <strong>@Model.StatusText</strong>
                <small class="d-block mt-1 opacity-75">Today: @Model.TodayHoursDisplay</small>
            </span>
        </div>

        <div>
            <a asp-controller="Menu" asp-action="Show" class="btn btn-outline-light btn-lg px-5 py-3 me-3">View Menu</a>
            <a asp-action="Contact" class="btn btn-outline-light btn-lg px-5 py-3">Reserve Table</a>
        </div>
    </div>
</section>
<div class="container">
    <div class="row text-center py-5">
        <p class="display-5">California inspired Mediterranean cooking with drinks to match from San Francisco natives and industry professionals</p>
        <p><a id="resyButton-4qry7w4i" href="https://resy.com/cities/sf/pearl">Book your Pearl reservation on Resy</a></p>
    </div>
</div>