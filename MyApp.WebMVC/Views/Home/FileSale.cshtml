@using Microsoft.AspNetCore.Http.Extensions
@model MyApp.WebMVC.Models.FileLinkViewModel

@{
    ViewData["Title"] = $"Buy {Model.FileDescription} - Crypto File";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<!-- SEO Meta Tags -->
@section Head {
    <meta name="description" content="Buy @Model.FileDescription for @Model.Price.ToString("N2") USD on Crypto File. Secure, instant delivery with blockchain payments." />
    <meta property="og:title" content="Buy @Model.FileDescription - Crypto File" />
    <meta property="og:description" content="Purchase @Model.FileDescription for only @Model.Price.ToString("N2") USD. Secure and instant delivery." />
    <meta property="og:url" content="@Context.Request.GetDisplayUrl()" />
    <meta property="og:image" content="@Url.Content("~/favicon.ico")" />
    <meta property="og:type" content="product" />
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "Product",
          "name": "@Model.FileDescription",
          "description": "Digital file for sale on Crypto File platform.",
          "offers": {
            "@@type": "Offer",
            "price": "@Model.Price.ToString("N2")",
            "priceCurrency": "USD",
            "availability": "https://schema.org/InStock"
          }
        }
    </script>
}




<!-- Main Content -->
<div class="container py-5">
    <div class="card shadow-sm mx-auto" style="max-width: 500px; margin-top: 100px;" data-aos="fade-up">
        <div class="card-header bg-primary text-white text-center">
            <h5 class="mb-0">Purchase File</h5>
        </div>
        <div class="card-body text-center">
            <img src="~/img/CryptoFile_With.png" alt="Crypto File Logo" class="img-fluid mb-3" style="max-width: 150px;">
            <h5 class="card-title mb-3"><span class="text-muted">File Description:</span> @Html.DisplayFor(model => model.FileDescription)</h5>
            <p class="card-text mb-2">
                <strong>Price:</strong> $@Model.Price.ToString("N2") USD
            </p>
            <p class="card-text text-muted mb-4">
                Pay securely with USDT and get instant access to your file.
            </p>
            <a asp-action="Pay" asp-route-fileLinkId="@Model.Id" class="btn btn-primary btn-lg btn-block  " aria-label="Pay for file">Pay Now</a>
            <div class="mt-3">
                <a href="mailto:cryptofile.runasp.net@outlook.com" class="text-muted"><i class="fas fa-envelope me-1"></i>Contact Support</a> |
                <a asp-controller="Home" asp-action="Privacy" class="text-muted"><i class="fas fa-lock me-1"></i>Privacy Policy</a>
            </div>
        </div>
        <div class="card-footer bg-light text-center">
            <small class="text-muted"><i class="fas fa-shield-alt me-1"></i>Secure blockchain transactions powered by TRON</small>
        </div>
    </div>

    <!-- Share Buttons -->
    <div class="text-center mt-3">
        <p>Share this file:</p>
        <a href="https://twitter.com/intent/tweet?url=@Context.Request.GetDisplayUrl()&text=Check%20out%20this%20file%20on%20Crypto%20File!"
           target="_blank" class="btn btn-outline-primary btn-sm mx-1">
            <i class="fab fa-twitter"></i> Share on X
        </a>

        <a href="https://t.me/share/url?url=@Context.Request.GetDisplayUrl()&text=Check%20out%20this%20file%20on%20Crypto%20File!"
           target="_blank" class="btn btn-outline-primary btn-sm mx-1">
            <i class="fab fa-telegram"></i> Share on Telegram
        </a>
    </div>

</div>
@inject IHostEnvironment Environment
@{
    if (Environment.IsDevelopment())
    {
        <a asp-action="TestCallback" target="_blank" class="btn btn-primary">TestCallback</a>
    }
}

@section Scripts {
    <!-- AOS for animations -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <!-- Animate.css for button animation -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <script>
        AOS.init();
    </script>
}