@{
    ViewData["Title"] = "Download Your File - Crypto File";
    var downloadUrl = Url.Action("GetFile", new { FileUrl = ViewBag.FileUrl });
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="text-center" data-aos="fade-up">
                <img src="~/img/CryptoFile_With.png" alt="Crypto File Logo for Secure File Trading" class="img-fluid mb-3" style="max-width: 300px; padding:0 30px">
                <h1 class="display-4 mb-4">Secure File Trading</h1>
                <h2>Payment Successful!</h2>
                <p class="text-muted mb-4">Thank you for your purchase. Your file is ready to download securely.</p>
                <hr />

                <!-- Success Message -->
                <div class="alert alert-success" role="alert" aria-live="assertive">
                    <i class="fas fa-check-circle me-2"></i>Your file is ready! Please save it in a secure location.
                </div>

                <!-- Download Section -->
                <div id="downloadSection">
                    <p id="countdown" class="mb-3">Download starting in <span id="timer">5</span> seconds...</p>
                    <a id="downloadLink" href="@downloadUrl" class="btn btn-success btn-lg animate__animated animate__pulse animate__infinite" aria-label="Download file"><i class="fas fa-download me-2"></i>Download Now</a>
                </div>

                <!-- Support Links -->
                <div class="mt-3">
                    <p class="text-muted">Having trouble? <a href="mailto:cryptofile.runasp.net@outlook.com"><i class="fas fa-envelope me-1"></i>Contact Support</a> | <a asp-controller="Home" asp-action="Privacy"><i class="fas fa-lock me-1"></i>Privacy Policy</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- AOS for animations -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <!-- Animate.css for button animation -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <script>
        AOS.init();

        // Countdown before auto-download
        window.onload = function () {
            let timeLeft = 5;
            const timerElement = document.getElementById('timer');
            const downloadLink = document.getElementById('downloadLink');

            const countdown = setInterval(function () {
                timeLeft--;
                timerElement.textContent = timeLeft;
                if (timeLeft <= 0) {
                    clearInterval(countdown);
                    document.getElementById('countdown').style.display = 'none';
                    downloadLink.click();
                }
            }, 1000);
        };
    </script>
}