@{
    ViewData["Title"] = "Terms of Service";
}
<style>

    .header-card {
        background: linear-gradient(135deg, #2c3e50, #3498db);
        color: white;
        border-radius: 15px;
        padding: 2rem;
    }

    .section-card {
        background-color: white;
        border-radius: 10px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        padding: 20px;
        margin-bottom: 20px;
    }

        .section-card h2 {
            color: #2c3e50;
            border-bottom: 2px solid #3498db;
            padding-bottom: 10px;
        }

    .list-custom {
        padding-left: 20px;
    }

        .list-custom li {
            margin-bottom: 10px;
        }

    .contact-info {
        background-color: #e9ecef;
        border-left: 4px solid #3498db;
        padding: 15px;
        border-radius: 5px;
    }

    .footer-text {
        font-size: 0.9rem;
    }
</style>

<!-- Main Content -->
<div class="container py-5">
    <div class="header-card mb-5">
        <h1 class="text-center mb-4"><i class="fas fa-file-contract"></i> Terms of Service</h1>
        <p class="lead text-center">Welcome to Crypto File! These Terms of Service govern your use of our platform for creating and selling file links using USDT. By using our service, you agree to these terms.</p>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-link"></i> 1. No File Hosting</h2>
        <p>Crypto File <strong>does not host, store, or access any files</strong>. You must upload your files to a third-party service (e.g., Google Drive, Mega, IPFS) and provide only the public link. We are not responsible for file availability, content, or security.</p>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-gavel"></i> 2. Seller Responsibility</h2>
        <p><strong>You are 100% responsible for the legality and ownership of the files you sell.</strong> This includes:</p>
        <ul class="list-custom">
            <li>No copyrighted, illegal, harmful, or infringing content</li>
            <li>No malware, viruses, or phishing links</li>
            <li>Compliance with all local and international laws</li>
        </ul>
        <p>We do not moderate content. Reported violations will result in immediate removal of your sales page and possible account termination.</p>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-ban"></i> 3. Prohibited Use</h2>
        <p>You may not use Crypto File to sell:</p>
        <ul class="list-custom">
            <li>Illegal goods or services</li>
            <li>Stolen data or hacked accounts</li>
            <li>Adult content (if against platform policy)</li>
            <li>Anything that violates USDT network rules or sanctions</li>
        </ul>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-handshake"></i> 4. Payments & Fees</h2>
        <p>We charge a <strong>2% fee</strong> per successful transaction. Payments are sent directly to your USDT wallet. We are not a custodian of funds.</p>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-trash-alt"></i> 5. Account Termination</h2>
        <p>We reserve the right to suspend or delete any account that violates these terms, with or without notice.</p>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-shield-alt"></i> 6. Limitation of Liability</h2>
        <p>Crypto File is not liable for:</p>
        <ul class="list-custom">
            <li>Lost files or broken links</li>
            <li>Failed transactions due to blockchain issues</li>
            <li>Any damages from user-generated content</li>
        </ul>
    </div>

    <div class="section-card">
        <h2><i class="fas fa-envelope"></i> 7. Contact Us</h2>
        <p class="contact-info">If you have questions or concerns about this Terms of Service, please reach out to us at:</p>
        <p class="contact-info"><strong>Email:</strong> cryptofile.runasp.net@outlook.com<br><strong>Address:</strong> 12 Emily St, Cambridge, MA 02139, USA</p>
    </div>

    <div class="text-center footer-text">
        <p class="text-muted">Last updated: September 28, 2025, 01:29 PM JST</p>
    </div>
</div>