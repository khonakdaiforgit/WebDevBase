<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Pearl</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <style>
        :root {
            --primary: #485c81; /* رنگ اصلی برندت حالا آبی-خاکستری لوگو */
            --primary-light: #647a9e;
            --primary-dark: #374863;
            --light: #ecf0f1;
            --dark: #2c3e50;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--dark);
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Playfair Display', serif;
        }

        .hero {
            background: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.7)), url('/photos/B18I6807-crop-large.jpeg') center/cover no-repeat fixed;
            min-height: 100vh;
            color: white;
        }

        /* وقتی navbar شفافه → لوگو و متن‌ها سفید باشن تا دیده بشن */
        .navbar {
            transition: all 0.4s ease;
        }

            /* حالت اولیه (شفاف) */
            .navbar .navbar-brand img {
                filter: brightness(0) invert(1); /* لوگو رو سفید می‌کنه */
                transition: filter 0.4s ease;
            }

            .navbar .nav-link,
            .navbar .btn-outline-light {
                color: white !important;
                transition: all 0.3s;
            }

                .navbar .nav-link:hover {
                    color: var(--primary-light) !important;
                }

        /* وقتی اسکرول شد و پس‌زمینه تیره شد */
        .navbar-scrolled {
            background: rgba(68, 68, 68, 0.51) !important;
            backdrop-filter: blur(12px);
        }

            .navbar-scrolled .nav-link,
            .navbar-scrolled .btn-outline-light {
                color: white !important;
            }

                .navbar-scrolled .nav-link:hover {
                    color: #a0b4d3 !important;
                }

        /* تنظیم اندازه لوگو در حالت‌های مختلف */
        .logo-img {
            width: 100px;
            height: auto;
            object-fit: contain;
        }

        @@media (max-width: 768px) {
            .logo-img

        {
            width: 80px;
        }

        }

        @@media (max-width: 576px) {
            .logo-img

        {
            width: 70px;
        }

        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg fixed-top navbar-dark">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/img/logo_200px.png"
                     alt="Pearl Logo"
                     class="me-3 logo-img" />
                <!-- اگر بعداً خواستی اسم Pearl رو هم نشون بدی، اینو فعال کن -->
                <!-- <span class="fw-bold fs-4" style="color: white;">Pearl</span> -->
            </a>

            <!-- بقیه navbar دقیقاً مثل قبلی -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link" href="#menu">Menu</a></li>
                    <li class="nav-item"><a class="nav-link" href="#gallery">Gallery</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item ms-3">
                            <a class="btn btn-outline-light px-4" href="/Dashboard">
                                <i class="fas fa-tachometer-alt me-1"></i> Dashboard
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-3">
                            <a class="btn btn-outline-light px-4" href="/Account/Login">Login</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <!-- Main Content -->
    @RenderBody()

    <!-- Footer -->
    <footer class="bg-black text-white py-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h4 class="mb-3">The Urban Bistro</h4>
                    <p>
                        123 Downtown Street • New York, NY 10001<br>
                        <i class="fas fa-phone"></i> +1 (555) 123-4567 • Open Daily 11AM – 11PM
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p>
                        &copy; @DateTime.Now.Year The Urban Bistro. All rights reserved.<br>
                        <a href="/Account/Login" class="text-white-50 small">Restaurant Admin Panel →</a>
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('.navbar');
            if (window.scrollY > 80) {
                nav.classList.add('navbar-scrolled');
            } else {
                nav.classList.remove('navbar-scrolled');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>