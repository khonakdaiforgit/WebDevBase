<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - The Urban Bistro</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <style>
        :root {
            --primary: #e74c3c;
            --dark: #2c3e50;
            --light: #ecf0f1;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--dark);
        }

        h1, h2, h3, h4, h5 {
            font-family: 'Playfair Display', serif;
        }

        .hero {
            background: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1517248135467-2c7ed3da9ab0') center/cover no-repeat fixed;
            min-height: 100vh;
            color: white;
        }

        .navbar-scrolled {
            background: rgba(44, 62, 80, 0.98) !important;
            backdrop-filter: blur(12px);
        }

        .card-hover:hover {
            transform: translateY(-10px);
            transition: 0.3s;
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }

        .fa-beat-fade {
            animation: beat 1.5s ease-in-out infinite;
        }

        @@keyframes beat {
            0%, 100%

        {
            transform: scale(1);
        }

        50% {
            transform: scale(1.2);
        }

        }
        .status-open {
            color: #27ae60;
        }

        .status-closed {
            color: #c0392b;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg fixed-top navbar-dark" style="background: transparent; transition: all 0.4s;">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3" href="/">The Urban Bistro</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link" href="#menu">Menu</a></li>
                    <li class="nav-item"><a class="nav-link" href="#gallery">Gallery</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item ms-3">
                            <a class="btn btn-outline-light px-4" href="/Dashboard">
                                <i class="fas fa-tachometer-alt me-1"></i> Dashboard
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-3">
                            <a class="btn btn-outline-light px-4" href="/Account/Login">Login</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    @RenderBody()

    <!-- Footer -->
    <footer class="bg-black text-white py-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h4 class="mb-3">The Urban Bistro</h4>
                    <p>
                        123 Downtown Street • New York, NY 10001<br>
                        <i class="fas fa-phone"></i> +1 (555) 123-4567 • Open Daily 11AM – 11PM
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p>
                        &copy; @DateTime.Now.Year The Urban Bistro. All rights reserved.<br>
                        <a href="/Account/Login" class="text-white-50 small">Restaurant Admin Panel →</a>
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('.navbar');
            if (window.scrollY > 80) {
                nav.classList.add('navbar-scrolled');
            } else {
                nav.classList.remove('navbar-scrolled');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>