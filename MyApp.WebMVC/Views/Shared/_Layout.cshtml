@using MyApp.Application.Helper
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Crypto File: Sell digital files securely using USDT. Register, set your wallet, add products, and share sales links for easy crypto earnings." />
    <meta name="keywords" content="sell files with USDT, crypto file marketplace, digital goods trading, USDT payments, secure file sales" />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content="Crypto File - Secure File Trading with USDT" />
    <meta property="og:description" content="Sell digital files securely using USDT. Register, set your wallet, add products, and share sales links for easy crypto earnings." />
    <meta property="og:url" content="@AppSettingsHelper.GetMvcAddress()" />
    <meta property="og:image" content="@AppSettingsHelper.GetMvcAddress()img/CryptoFile_With.png" />
    <meta property="og:type" content="website" />
    @* <meta name="google-site-verification" content="xIw4BroVEE5luCUqK2WWq4EEp2xiZa9w9EEorubmFSI" /> *@
    @* <meta name="google-site-verification" content="rR6alDaODsmcPADudzjjs7fu2fR3UiOL7arM5Lbp-Sw" /> *@
    <meta name="google-site-verification" content="rR6alDaODsmcPADudzjjs7fu2fR3UiOL7arM5Lbp-Sw" />
    <link rel="icon" href="~/favicon.ico" type="image/x-icon" />
    <title>@ViewData["Title"] - Crypto File</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyApp.WebMVC.styles.css" asp-append-version="true" />
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "WebSite",
          "name": "Crypto File",
          "url": "@AppSettingsHelper.GetMvcAddress()",
          "description": "Platform for selling digital files using USDT cryptocurrency."
        }
    </script>
    @RenderSection("Head", required: false)   <!-- 👈 Add this line -->
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Crypto File</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Fees">Fees</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="ContactMessage" asp-action="Create">Contact & Support</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
         
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
            - <a asp-area="" asp-controller="Home" asp-action="AffiliateProgram">Affiliate Program</a>
            - <a asp-area="" asp-controller="Home" asp-action="Terms">Terms of Service</a>
           <br />
                &copy; 2025 - Crypto File
        
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
