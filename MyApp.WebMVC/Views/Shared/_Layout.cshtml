@using MyApp.WebMVC.Views.Shared.ViewModels
@{
    var layoutData = ViewData["LayoutData"] as SharedLayoutViewModel
                    ?? new SharedLayoutViewModel(); // fallback اگر چیزی نبود
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Pearl</title>

    <link rel="icon" type="image/png" href="/favicon.png">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <link href="~/css/style.css" rel="stylesheet" />

    @await RenderSectionAsync("Styles", required: false)

</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg fixed-top navbar-dark">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/img/logo_200px.png"
                     alt="Pearl Logo"
                     class="me-3 logo-img" />
                <!-- اگر بعداً خواستی اسم Pearl رو هم نشون بدی، اینو فعال کن -->
                <!-- <span class="fw-bold fs-4" style="color: white;">Pearl</span> -->
            </a>

            <!-- بقیه navbar دقیقاً مثل قبلی -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Menu" asp-action="Show">Menu</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Gallery" asp-action="Show">Gallery</a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="News" asp-action="AllNews" class="nav-link">News & Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a>
                    </li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item ms-3">
                            <a class="btn btn-outline-light px-4" href="/Dashboard">
                                <i class="fas fa-tachometer-alt me-1"></i> Dashboard
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-3">
                            <a class="btn btn-outline-light px-4" href="/Account/Login">Login</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <!-- Main Content -->
    @RenderBody()


    <!-- Footer -->
    <footer class="bg-dark text-white pt-5 pb-1">
        <div class="container">
            <div class="row gy-5">
                <!-- Left: Info -->
                <div class="col-lg-4">
                    <h4 class="mb-3 text-primary">@layoutData.RestaurantName</h4>

                    <p class="mb-2">
                        @layoutData.FullAddress<br>
                        <i class="fas fa-phone me-2"></i> <a href="tel:@layoutData.Phone.Replace(" ", "")" class="text-white text-decoration-none">@layoutData.Phone</a>
                    </p>

                    <p class="mb-3 text-white-50">
                        @layoutData.TodayHoursDisplay
                        @if (layoutData.IsOpenNow)
                        {
                            <span class="badge bg-success ms-2 small">Open Now</span>
                        }
                        else
                        {
                            <span class="badge bg-danger ms-2 small">Closed</span>
                        }
                    </p>

                    <!-- دکمه جدید: باز کردن در گوگل مپ -->
                    <a href="https://maps.app.goo.gl/rJdyt1ZRYuWxMd2TA"
                       target="_blank"
                       class="btn btn-outline-light btn-sm px-4 py-2 d-inline-flex align-items-center gap-2">
                        <i class="fas fa-map-marker-alt"></i>
                        View on Google Maps
                    </a>
                </div>

                <!-- Center: Newsletter -->
                <div class="col-lg-4">
                    <h5 class="mb-3">Email Subscribe</h5>
                    <p class="text-white-50 mb-3 small">
                        Get exclusive offers, new menu alerts & event invitations
                    </p>

                    <form id="newsletterFooterForm" class="d-flex flex-column flex-sm-row gap-2 max-w-md mx-auto">
                        @Html.AntiForgeryToken()
                        <input type="email"
                               name="email"
                               class="form-control"
                               placeholder="your@email.com"
                               required
                               autocomplete="email" />
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </form>

                    <div id="newsletterFooterMessage" class="mt-3 small"></div>
                </div>

                <div class="col-lg-4">
                    <h5 class="mb-3">Connect</h5>
                    <div class="d-flex justify-content-center gap-4">
                        <a href="https://www.yelp.com/biz/pearl-san-francisco" target="_blank" class="text-white hover:text-primary transition">
                            <i class="fab fa-yelp fa-2x"></i>
                        </a>
                        <a href="https://www.instagram.com/pearl_6101/" target="_blank" class="text-white hover:text-primary transition">
                            <i class="fab fa-instagram fa-2x"></i>
                        </a>
                    </div>
                </div>

            </div>

        </div>

        <div class="row">
            <div class="text-center">
                <p class="mt-4">
                    &copy; @DateTime.Now.Year @layoutData.RestaurantName
                    <span class="text-white-50 small"> All rights reserved.</span>
                </p>
            </div>

        </div>

    </footer>
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>


    <script>
        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('.navbar');
            if (window.scrollY > 80) {
                nav.classList.add('navbar-scrolled');
            } else {
                nav.classList.remove('navbar-scrolled');
            }
        });


    </script>


    <script>
        const newsletterForm = document.getElementById('newsletterFooterForm');

        if (newsletterForm) {
            newsletterForm.addEventListener('submit', async function (e) {
                e.preventDefault();

                const emailInput = newsletterForm.querySelector('input[name="email"]');
                const messageDiv = document.getElementById('newsletterFooterMessage');
                const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');

                if (!tokenInput) {
                    messageDiv.innerHTML = '<span class="text-danger">Security token missing.</span>';
                    return;
                }

                const token = tokenInput.value;
                const email = emailInput.value.trim();

                if (!email) {
                    messageDiv.innerHTML = '<span class="text-danger"><i class="fas fa-exclamation-triangle me-1"></i>Please enter your email</span>';
                    return;
                }

                messageDiv.innerHTML = '<span class="text-info"><i class="fas fa-spinner fa-spin me-1"></i>Sending...</span>';

                try {
                    const response = await fetch('/subscribe', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({ email: email })   // مهم!
                    });

                    if (!response.ok) {
                        if (response.status === 403 || response.status === 400) {
                            messageDiv.innerHTML = '<span class="text-danger"><i class="fas fa-shield-alt me-1"></i>Security check failed. Please refresh.</span>';
                            return;
                        }
                    }

                    const result = await response.json();

                    if (result.success) {
                        messageDiv.innerHTML = '<span class="text-success"><i class="fas fa-check-circle me-1"></i>' + result.message + '</span>';
                        emailInput.value = '';
                    } else {
                        messageDiv.innerHTML = '<span class="text-danger"><i class="fas fa-times-circle me-1"></i>' + result.message + '</span>';
                    }

                } catch (err) {
                    console.error("Fetch error:", err);
                    messageDiv.innerHTML = '<span class="text-danger"><i class="fas fa-wifi me-1"></i>Connection failed.</span>';
                }

                setTimeout(() => messageDiv.innerHTML = '', 8000);
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>