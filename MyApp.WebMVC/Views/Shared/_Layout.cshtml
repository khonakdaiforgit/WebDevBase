<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Pearl</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <style>
        :root {
            --primary: #485c81; /* رنگ اصلی برندت حالا آبی-خاکستری لوگو */
            --primary-light: #647a9e;
            --primary-dark: #374863;
            --light: #ecf0f1;
            --dark: #2c3e50;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--dark);
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Playfair Display', serif;
        }

        .hero {
            background: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.7)), url('/photos/B18I6807-crop-large.jpeg') center/cover no-repeat fixed;
            min-height: 100vh;
            color: white;
        }

        /* وقتی navbar شفافه → لوگو و متن‌ها سفید باشن تا دیده بشن */
        .navbar {
            transition: all 0.4s ease;
        }

            /* حالت اولیه (شفاف) */
            .navbar .navbar-brand img {
                filter: brightness(0) invert(1); /* لوگو رو سفید می‌کنه */
                transition: filter 0.4s ease;
            }

            .navbar .nav-link,
            .navbar .btn-outline-light {
                color: white !important;
                transition: all 0.3s;
            }

                .navbar .nav-link:hover {
                    color: var(--primary-light) !important;
                }

        /* وقتی اسکرول شد و پس‌زمینه تیره شد */
        .navbar-scrolled {
            background: rgba(68, 68, 68, 0.51) !important;
            backdrop-filter: blur(12px);
        }

            .navbar-scrolled .nav-link,
            .navbar-scrolled .btn-outline-light {
                color: white !important;
            }

                .navbar-scrolled .nav-link:hover {
                    color: #a0b4d3 !important;
                }

        /* تنظیم اندازه لوگو در حالت‌های مختلف */
        .logo-img {
            width: 100px;
            height: auto;
            object-fit: contain;
        }

        @@media (max-width: 768px) {
            .logo-img {
                width: 80px;
            }
        }

        @@media (max-width: 576px) {
            .logo-img {
                width: 70px;
            }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg fixed-top navbar-dark">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/img/logo_200px.png"
                     alt="Pearl Logo"
                     class="me-3 logo-img" />
                <!-- اگر بعداً خواستی اسم Pearl رو هم نشون بدی، اینو فعال کن -->
                <!-- <span class="fw-bold fs-4" style="color: white;">Pearl</span> -->
            </a>

            <!-- بقیه navbar دقیقاً مثل قبلی -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link" href="#menu">Menu</a></li>
                    <li class="nav-item"><a class="nav-link" href="#gallery">Gallery</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item ms-3">
                            <a class="btn btn-outline-light px-4" href="/Dashboard">
                                <i class="fas fa-tachometer-alt me-1"></i> Dashboard
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-3">
                            <a class="btn btn-outline-light px-4" href="/Account/Login">Login</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <!-- Main Content -->
    @RenderBody()

    <!-- Footer -->
    <!-- Footer -->
    <footer class="bg-dark text-white py-5">
        <div class="container">
            <div class="row gy-5 align-items-center">
                <!-- Left: Info -->
                <div class="col-lg-5">
                    <h4 class="mb-3 text-primary">The Urban Bistro</h4>
                    <p class="mb-2">
                        123 Downtown Street • New York, NY 10001<br>
                        <i class="fas fa-phone me-2"></i> +1 (555) 123-4567
                    </p>
                    <p class="mb-0 text-white-50">
                        Open Daily • 11:00 AM – 11:00 PM
                    </p>
                </div>

                <!-- Center: Newsletter -->
                <div class="col-lg-4 text-center">
                    <h5 class="mb-3">Stay Connected</h5>
                    <p class="text-white-50 mb-3 small">
                        Get exclusive offers, new menu alerts & event invitations
                    </p>

                    <form id="newsletterFooterForm" class="d-flex flex-column flex-sm-row gap-2 max-w-md mx-auto">
                        @Html.AntiForgeryToken()
                        <input type="email"
                               name="email"
                               class="form-control form-control-lg rounded-pill"
                               placeholder="your@email.com"
                               required
                               autocomplete="email" />
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill px-4">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </form>

                    <div id="newsletterFooterMessage" class="mt-3 small"></div>
                </div>

                <!-- Right: Copyright + Admin Link -->
                <div class="col-lg-3 text-center text-lg-end">
                    <p class="mb-2">
                        &copy; @DateTime.Now.Year The Urban Bistro<br>
                        <span class="text-white-50 small">All rights reserved.</span>
                    </p>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/Dashboard" class="btn btn-outline-light btn-sm mt-2">
                            <i class="fas fa-tachometer-alt me-1"></i> Dashboard
                        </a>
                    }
                    else
                    {
                        <a href="/Account/Login" class="text-white-50 small text-decoration-underline">
                            Restaurant Admin Panel →
                        </a>
                    }
                </div>
            </div>
        </div>
    </footer>
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>


    <script>
        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('.navbar');
            if (window.scrollY > 80) {
                nav.classList.add('navbar-scrolled');
            } else {
                nav.classList.remove('navbar-scrolled');
            }
        });


    </script>


    <script>
        const newsletterForm = document.getElementById('newsletterFooterForm');

        if (newsletterForm) {
            newsletterForm.addEventListener('submit', async function (e) {
                e.preventDefault();

                const emailInput = newsletterForm.querySelector('input[name="email"]');
                const messageDiv = document.getElementById('newsletterFooterMessage');
                const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');

                if (!tokenInput) {
                    messageDiv.innerHTML = '<span class="text-danger">Security token missing.</span>';
                    return;
                }

                const token = tokenInput.value;
                const email = emailInput.value.trim();

                if (!email) {
                    messageDiv.innerHTML = '<span class="text-danger"><i class="fas fa-exclamation-triangle me-1"></i>Please enter your email</span>';
                    return;
                }

                messageDiv.innerHTML = '<span class="text-info"><i class="fas fa-spinner fa-spin me-1"></i>Sending...</span>';

                try {
                    const response = await fetch('/subscribe', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({ email: email })   // مهم!
                    });

                    if (!response.ok) {
                        if (response.status === 403 || response.status === 400) {
                            messageDiv.innerHTML = '<span class="text-danger"><i class="fas fa-shield-alt me-1"></i>Security check failed. Please refresh.</span>';
                            return;
                        }
                    }

                    const result = await response.json();

                    if (result.success) {
                        messageDiv.innerHTML = '<span class="text-success"><i class="fas fa-check-circle me-1"></i>' + result.message + '</span>';
                        emailInput.value = '';
                    } else {
                        messageDiv.innerHTML = '<span class="text-danger"><i class="fas fa-times-circle me-1"></i>' + result.message + '</span>';
                    }

                } catch (err) {
                    console.error("Fetch error:", err);
                    messageDiv.innerHTML = '<span class="text-danger"><i class="fas fa-wifi me-1"></i>Connection failed.</span>';
                }

                setTimeout(() => messageDiv.innerHTML = '', 8000);
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>