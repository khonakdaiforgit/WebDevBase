@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Crypto File Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        body {
            font-size: 1rem;
            background-color: #f8f9fa;
        }

        .sidebar {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 100;
            padding: 56px 0 0;
            background-color: #1e2a44; /* Crypto-themed dark blue */
            color: #fff;
            box-shadow: inset -1px 0 0 rgba(0, 0, 0, .2);
        }

        .sidebar-sticky {
            position: relative;
            top: 0;
            height: calc(100vh - 56px);
            padding-top: 1rem;
            overflow-x: hidden;
            overflow-y: auto;
        }

        .sidebar .admin {
            background-color: black !important;
            transition: background-color 0.3s;
        }

        .sidebar .nav-link {
            color: #fff;
            transition: background-color 0.3s;
        }

            .sidebar .nav-link:hover {
                background-color: #00C4B4; /* Crypto green */
            }

            .sidebar .nav-link.active {
                background-color: #00C4B4 !important;
                color: #fff !important;
            }

        .main-content {
            margin-left: 220px;
            padding: 30px;
        }

        .navbar {
            background-color: #1a237e !important; /* Darker blue for header */
        }

        .navbar-brand {
            padding: 0.75rem;
            font-size: 1.2rem;
            color: #fff !important;
        }

        .navbar-nav .nav-link {
            color: #fff !important;
        }

        @@media (max-width: 767.98px) {
            .sidebar {
                position: static;
                width: 100%;
                height: auto;
                padding-top: 0;
                box-shadow: none;
            }

            .main-content {
                margin-left: 0;
            }

            .navbar-toggler {
                position: absolute;
                right: 15px; /* فاصله از سمت راست */
                top: 10px; /* فاصله از بالا */
            }

            .navbar-brand {
                padding-left: 15px; /* فاصله از سمت چپ */
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="navbar navbar-dark sticky-top flex-md-nowrap p-0 shadow">
        <a class="navbar-brand col-md-3 col-lg-2 me-0 px-3" href="#">Crypto File</a>
        <button class="navbar-toggler position-absolute d-md-none collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        @* <div class="navbar-nav ms-auto"> 
            <div class="nav-item text-nowrap">
                <a class="nav-link px-3" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a>
            </div>
        </div>*@
    </header>

    <!-- Main Container -->
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse" data-aos="fade-right">
                <div class="sidebar-sticky pt-3">
                    <ul class="nav flex-column">
                        @if (User.Claims.Any(c => c.Value == "Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link admin @(currentController == "Dashboard" && currentAction == "Index" ? "active" : null)" asp-controller="Dashboard" asp-action="Index" title="View your dashboard">
                                    <i class="bi bi-house-door me-2"></i>Admin Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link admin @(currentController == "Dashboard" && currentAction == "Logs" ? "active" : null)" asp-controller="Dashboard" asp-action="Logs" title="View your dashboard">
                                    <i class="bi bi-journal-text me-2"></i>Logs
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link admin @(currentController == "ContactMessage" && (currentAction == "UserContactMessages" || currentAction == "ContactMessagesDetails") ? "active" : null)"
                                   asp-controller="ContactMessage"
                                   asp-action="UserContactMessages" title="View your dashboard">
                                    <i class="bi bi-envelope-fill me-2"></i>User Messages
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "UserProfile" && currentAction == "Index" ? "active" : null)" asp-controller="UserProfile" asp-action="Index" title="View your dashboard">
                                <i class="bi bi-house-door me-2"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "UserProducts" ? "active" : null)" asp-controller="UserProducts" asp-action="Index" title="Manage your products">
                                <i class="bi bi-cart me-2"></i>Products
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "UserProfile" && currentAction == "UpdateWallet" ? "active" : null)" asp-controller="UserProfile" asp-action="UpdateWallet" title="Update your wallet settings">
                                <i class="bi bi-person-gear me-2"></i>User Settings
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "UserProfile" && currentAction == "Affiliate" ? "active" : null)"
                               asp-controller="UserProfile"
                               asp-action="Affiliate"
                               title="Your affiliate link">
                                <i class="bi bi-link-45deg me-2"></i>Affiliate
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "ContactMessage" && currentAction == "Create" ? "active" : null)"
                               asp-controller="ContactMessage"
                               asp-action="Create"
                               title="Contact our support team">
                                <i class="bi bi-envelope-fill me-2"></i>Contact Support
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Logout">
                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main Content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content">


                @RenderBody()

                <!-- Footer -->
                <footer class="bg-light text-center py-3 mt-4">
                    <p>&copy; 2025 Crypto File. Your data is encrypted and secure. <a href="mailto:cryptofile.runasp.net@outlook.com">Contact Support</a> | <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a></p>
                </footer>
            </main>
        </div>
    </div>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <script>
        AOS.init();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>