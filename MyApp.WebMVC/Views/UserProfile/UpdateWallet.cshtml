@model MyApp.WebMVC.Models.UserProfileViewModel

@{
    ViewData["Title"] = "Update Your USDT Wallet";
    Layout = "~/Views/Shared/_DashLayout.cshtml";
}

<!-- Header Section -->

    <h1 class="mb-3" data-aos="fade-up">Update Your USDT Wallet</h1>
    <p class="text-muted">Enter your USDT wallet address (TRC-20) to receive payments instantly. Ensure the address is correct to avoid payment issues.</p>
    <hr />

    <!-- Success Message (Conditional) -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Form Section -->
    <div class="row">
        <div class="col-md-6">
            <form asp-action="UpdateWallet" id="walletForm">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input asp-for="Id" hidden />
                <div class="form-group mb-3">
                    <label asp-for="WalletAddress" class="control-label fw-bold">USDT Wallet Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-wallet"></i></span>
                        <input asp-for="WalletAddress" class="form-control" placeholder="Enter your TRC-20 USDT address (e.g., Txxx...)" aria-describedby="walletHelp" />
                    </div>
                    <small id="walletHelp" class="form-text text-muted">Double-check your address. Incorrect addresses may lead to lost funds.</small>
                    <span asp-validation-for="WalletAddress" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <button type="submit" class="btn btn-primary animate__animated animate__pulse animate__infinite">Update Wallet</button>
                    <a href="mailto:cryptofile.runasp.net@outlook.com" class="btn btn-outline-secondary ms-2">Contact Support</a>
                </div>
            </form>
        </div>
        <div class="col-md-6">
            <div class="card p-3">
                <h5>Why Update Your Wallet?</h5>
                <p>Your wallet address ensures instant USDT payments for your file sales. We securely store it and never share it with third parties.</p>
                <ul class="list-unstyled">
                    <li><i class="fas fa-check-circle text-success me-2"></i>Supports TRC-20 USDT wallets</li>
                    <li><i class="fas fa-check-circle text-success me-2"></i>Encrypted storage for privacy</li>
                    <li><i class="fas fa-check-circle text-success me-2"></i>Direct payments with 2% fee</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Security Note -->
    <div class="alert alert-info mt-4" role="alert">
        <i class="fas fa-lock me-2"></i> Your wallet address is encrypted and secure. We do not store your private keys or access your funds.
    </div>


@section Scripts {
    <!-- AOS for animations -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <!-- Animate.css for button animation -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <script>
        AOS.init();

        // Basic client-side wallet address validation (example for TRON TRC-20)
        document.getElementById('walletForm').addEventListener('submit', function (e) {
            const walletAddress = document.querySelector('#WalletAddress').value;
            if (walletAddress.length !== 34 || !walletAddress.startsWith('T')) {
                alert('Please enter a valid TRC-20 USDT wallet address starting with "T" and 34 characters long.');
                e.preventDefault();
            }
        });
    </script>
    <!-- ASP.NET Validation Scripts -->
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}