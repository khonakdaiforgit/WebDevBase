@model MyApp.WebMVC.Models.UserDashboardDataViewModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_DashLayout.cshtml";
}

    <h1 class="mb-4">Welcome, @Model.UserId!</h1>

    @if (!string.IsNullOrEmpty(ViewBag.Error))
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <!-- اطلاعات پایه -->
    <div class="card mb-4">
        <div class="card-header">
            <h3>Profile Summary</h3>
        </div>
        <div class="card-body">
            <p><strong>Total Revenue:</strong> $@Model.TotalRevenue.ToString("N2")</p>
        </div>
    </div>

    <!-- نمودارها -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h3>Daily Revenue (Last 30 Days)</h3>
                </div>
                <div class="card-body">
                    <canvas id="revenueChart" height="100"></canvas>
                </div>
            </div>
        </div>
    </div>

@section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            // Line chart for daily revenue
            const revenueData = {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueByDay.Keys.Select(d => d.ToString("yyyy-MM-dd")))),
                datasets: [{
                    label: 'Daily Revenue ($)',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueByDay.Values)),
                    backgroundColor: 'rgba(75, 192, 192, 0.2)',
                    borderColor: 'rgba(75, 192, 192, 1)',
                    borderWidth: 2,
                    fill: true, // Fill the area under the line
                    tension: 0.4, // Smooth the line (0 for straight, 0.4 for curved)
                    pointBackgroundColor: 'rgba(75, 192, 192, 1)',
                    pointBorderColor: '#fff',
                    pointHoverBackgroundColor: '#fff',
                    pointHoverBorderColor: 'rgba(75, 192, 192, 1)'
                }]
            };

            const revenueCtx = document.getElementById('revenueChart').getContext('2d');
            new Chart(revenueCtx, {
                type: 'line', // Changed from 'bar' to 'line'
                data: revenueData,
                options: {
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) { return '$' + value.toFixed(2); } // Ensure two decimal places for Y-axis labels
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top'
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return `$${context.parsed.y.toFixed(2)}`; // Ensure two decimal places in tooltips
                                }
                            }
                        }
                    }
                }
            });
        </script>
}
