@model List<MyApp.WebMVC.Views.Menu.ViewModels.MenuCategoryViewModel>
@{
    ViewData["Title"] = "Menu Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-white border-bottom mb-4">
            <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Menu Management</li>
        </ol>
    </nav>

    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-list-alt text-primary"></i> Menu Management
        </h1>
        <a asp-action="CreateCategory" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus me-1"></i> Add New Category
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div id="categories-list" class="sortable">
        @foreach (var category in Model.OrderBy(c => c.Order))
        {
            <div class="card shadow mb-4 border-left-primary" data-id="@category.Id">
                <div class="card-header py-3 d-flex justify-content-between align-items-center bg-gradient-light">
                    <h5 class="m-0 font-weight-bold text-primary">@category.Name <small class="text-muted">(Order: @category.Order)</small></h5>
                    <div>
                        <a asp-action="EditCategory" asp-route-id="@category.Id" class="btn btn-sm btn-warning shadow-sm"><i class="fas fa-edit"></i> Edit</a>
                        <form asp-action="DeleteCategory" asp-route-id="@category.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger shadow-sm"
                                    onclick="return confirm('Are you sure you want to delete \" @category.Name\"? This will remove all items inside and cannot be undone.');">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </form>
                        <a asp-action="CreateItem" asp-route-categoryId="@category.Id" class="btn btn-sm btn-success shadow-sm"><i class="fas fa-plus"></i> Add Item</a>
                    </div>
                </div>
                <div class="card-body">
                    <ul class="list-group sortable-items flush" data-category-id="@category.Id">
                        @foreach (var item in category.Items)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center" data-id="@item.Id">
                                <div class="d-flex align-items-center">
                                    <img src="@item.ImageUrl" alt="@item.Name" class="rounded me-3" style="width: 60px; height: 60px; object-fit: cover;" />
                                    <div>
                                        <strong>@item.Name</strong> - <span class="text-success">$@item.Price.ToString("N2")</span><br />
                                        <small class="text-muted">@item.Description</small>
                                    </div>
                                </div>
                                <div>
                                    <form asp-action="ToggleAvailability" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(item.IsAvailable ? "btn-success" : "btn-secondary") shadow-sm">
                                            <i class="fas fa-toggle-@(item.IsAvailable ? "on" : "off")"></i> @(item.IsAvailable ? "Available" : "Unavailable")
                                        </button>
                                    </form>
                                    <a asp-action="EditItem" asp-route-id="@item.Id" class="btn btn-sm btn-warning shadow-sm"><i class="fas fa-edit"></i> Edit</a>
                                    <form asp-action="DeleteItem" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger shadow-sm"
                                                onclick="return confirm('Are you sure you want to permanently delete \" @item.Name\"? This action cannot be undone.');">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </li>
                        }
                    </ul>
                    @if (!category.Items.Any())
                    {
                        <div class="text-center text-muted mt-3">
                            <i class="fas fa-info-circle me-2"></i> No items yet. Add one to get started!
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <script>
        // Drag & Drop برای دسته‌ها
        new Sortable(document.getElementById('categories-list'), {
            handle: '.card-header',
            animation: 150,
            onEnd: async function (evt) {
                const orderedIds = Array.from(document.querySelectorAll('#categories-list .card')).map(card => card.dataset.id);
                await fetch('/Menu/ReorderCategories', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(orderedIds)
                });
            }
        });

        // Drag & Drop برای آیتم‌ها در هر دسته
        document.querySelectorAll('.sortable-items').forEach(list => {
            new Sortable(list, {
                animation: 150,
                onEnd: async function (evt) {
                    const categoryId = list.dataset.categoryId;
                    const orderedIds = Array.from(list.querySelectorAll('li')).map(li => li.dataset.id);
                    await fetch(`/Menu/ReorderItems?categoryId=${categoryId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(orderedIds)
                    });
                }
            });
        });
    </script>
}