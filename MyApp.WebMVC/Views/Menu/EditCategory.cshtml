@model MyApp.WebMVC.Views.Menu.ViewModels.UpdateCategoryViewModel
@{
    ViewData["Title"] = "Edit Menu Category";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-white border-bottom mb-4">
            <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Menu">Menu Management</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit Category</li>
        </ol>
    </nav>

    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-edit text-warning"></i> Edit Menu Category
        </h1>
        <a asp-action="Index" class="btn btn-secondary shadow-sm">
            <i class="fas fa-arrow-left me-1"></i> Back to Menu
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4 border-left-warning">
                <div class="card-header py-3 bg-gradient-warning text-white">
                    <h6 class="m-0 font-weight-bold"><i class="fas fa-pencil-alt me-2"></i> Update Details</h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditCategory" method="post" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold text-gray-700">Category Name</label>
                            <input asp-for="Name" class="form-control form-control-lg shadow-sm" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Order" class="form-label fw-bold text-gray-700">Display Order</label>
                            <input asp-for="Order" type="number" class="form-control shadow-sm" min="0" max="100" />
                            <small class="form-text text-muted">Adjust to reorder in the menu.</small>
                        </div>

                        <button type="submit" class="btn btn-warning btn-lg shadow-sm"><i class="fas fa-save me-2"></i> Update Category</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow mb-4 border-left-secondary">
                <div class="card-header py-3 bg-gradient-secondary text-white">
                    <h6 class="m-0 font-weight-bold"><i class="fas fa-info me-2"></i> Editing Tips</h6>
                </div>
                <div class="card-body text-gray-800">
                    <ul class="fa-ul">
                        <li><span class="fa-li"><i class="fas fa-sync text-secondary"></i></span> Update names to reflect seasonal changes (e.g., "Summer Specials").</li>
                        <li><span class="fa-li"><i class="fas fa-dollar-sign text-secondary"></i></span> Reorder to highlight high-margin items first.</li>
                        <li><span class="fa-li"><i class="fas fa-chart-line text-secondary"></i></span> Monitor sales impact after changes.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // اعتبارسنجی Bootstrap
        (() => {
            'use strict';
            const forms = document.querySelectorAll('.needs-validation');
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        })();
    </script>
}