@model MyApp.WebMVC.Views.Menu.ViewModels.CreateCategoryViewModel
@{
    ViewData["Title"] = "Create New Menu Category";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <!-- Breadcrumb برای ناوبری رسمی -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-white border-bottom mb-4">
            <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Menu">Menu Management</a></li>
            <li class="breadcrumb-item active" aria-current="page">Create Category</li>
        </ol>
    </nav>

    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-folder-plus text-primary"></i> Create New Menu Category
        </h1>
        <a asp-action="Index" class="btn btn-secondary shadow-sm">
            <i class="fas fa-arrow-left me-1"></i> Back to Menu
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4 border-left-primary">
                <div class="card-header py-3 bg-gradient-primary text-white">
                    <h6 class="m-0 font-weight-bold"><i class="fas fa-info-circle me-2"></i> Category Details</h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="CreateCategory" method="post" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold text-gray-700">Category Name</label>
                            <input asp-for="Name" class="form-control form-control-lg shadow-sm" placeholder="e.g., Appetizers" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Order" class="form-label fw-bold text-gray-700">Display Order</label>
                            <input asp-for="Order" type="number" class="form-control shadow-sm" min="0" max="100" value="0" />
                            <small class="form-text text-muted">Lower numbers appear first in the menu (0-100).</small>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg shadow-sm"><i class="fas fa-save me-2"></i> Create Category</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow mb-4 border-left-info">
                <div class="card-header py-3 bg-gradient-info text-white">
                    <h6 class="m-0 font-weight-bold"><i class="fas fa-lightbulb me-2"></i> Best Practices</h6>
                </div>
                <div class="card-body text-gray-800">
                    <ul class="fa-ul">
                        <li><span class="fa-li"><i class="fas fa-tags text-info"></i></span> Use clear, appetizing names like "Starters" or "Desserts".</li>
                        <li><span class="fa-li"><i class="fas fa-sort-numeric-up text-info"></i></span> Order categories logically (e.g., Appetizers first).</li>
                        <li><span class="fa-li"><i class="fas fa-users text-info"></i></span> Tailor to American tastes: Include sections for "Burgers" or "Salads".</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // اعتبارسنجی Bootstrap
        (() => {
            'use strict';
            const forms = document.querySelectorAll('.needs-validation');
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        })();
    </script>
}