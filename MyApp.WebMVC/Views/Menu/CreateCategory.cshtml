@model MyApp.WebMVC.Views.Menu.ViewModels.CreateCategoryViewModel
@{
    ViewData["Title"] = "Create Category";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Create New Category</h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Menu
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="CreateCategory" method="post" class="needs-validation" novalidate>
        @Html.AntiForgeryToken()

        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-folder-plus"></i> New Menu Category
                </h6>
                <small class="text-muted">Add a new section to your menu</small>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Category Name</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g., Appetizers, Burgers, Desserts" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

            @*     <div class="mb-3">
                    <label asp-for="Order" class="form-label">Display Order</label>
                    <input asp-for="Order" type="number" class="form-control" min="0" max="100" value="0" />
                    <div class="form-text">Lower numbers appear first (0 = top)</div>
                </div> *@
            </div>

            <div class="card-footer text-center bg-light">
                <button type="submit" class="btn btn-lg btn-primary px-5">
                    <i class="fas fa-save"></i> Create Category
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}