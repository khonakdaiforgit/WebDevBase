@model List<MyApp.WebMVC.Views.Menu.ViewModels.PublicMenuCategoryViewModel>
@{
    ViewData["Title"] = "Menu";
}

<section class="page">
    <div class="container bg-white">
        <div class="row">
            <div class="col-12 text-center mb-5">
                <h1 class="display-4">Our Menu</h1>
                <p class="lead text-muted">Friends, please be advised that a 4% Surcharge will be added to all items for Employee Health Benefits. Let us know if you would like this surcharge removed.</p>
            </div>
        </div>

        @if (Model.Any())
        {
            @foreach (var category in Model)
            {
                <h2 class="mt-5 mb-4 border-bottom pb-3 text-primary" data-aos="fade-right">@category.Name</h2>
                <div class="row g-4">
                    @foreach (var item in category.Items)
                    {
                        <div class="col-md-6 col-lg-4" data-aos="zoom-in">
                            <div class="card h-100 shadow-sm border-0 overflow-hidden">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height:200px; object-fit:cover;">
                                }
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title mb-2">@item.Name</h5>
                                    <p class="card-text text-muted flex-grow-1 small">@item.Description</p>
                                    <div class="mt-3">
                                        <span class="h4 text-primary mb-0">$@item.Price.ToString("0.00")</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <p class="text-center text-muted fs-5">Menu is empty at the moment.</p>
        }
    </div>
</section>