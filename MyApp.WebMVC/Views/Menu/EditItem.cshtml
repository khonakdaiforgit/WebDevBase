@model MyApp.WebMVC.Views.Menu.ViewModels.UpdateMenuItemViewModel
@{
    ViewData["Title"] = "Edit Menu Item";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Edit Menu Item</h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Menu
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="EditItem" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-edit"></i> Update Menu Item
                </h6>
                <small class="text-muted">Modify details or photo</small>
            </div>

            <div class="card-body">
                <div class="row">
                    <div class="col-md-8 mb-3">
                        <label asp-for="Name" class="form-label">Item Name</label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Price" class="form-label">Price ($)</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" min="0.01" required />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description (Optional)</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-3 text-center">
                        <label class="form-label">Current Photo</label>
                        <img src="@Model.ImageUrl" class="img-fluid rounded shadow" style="max-height:280px;" alt="Current" />
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="ImageFile" class="form-label">Replace Photo (Optional)</label>
                    <input asp-for="ImageFile" type="file" accept="image/*" class="form-control" id="ImageFile" />
                </div>

                <div id="imagePreview" class="text-center mb-3" style="display:none;">
                    <img id="previewImg" src="" class="img-fluid rounded shadow" style="max-height:280px;" alt="New Preview" />
                </div>

                <div class="form-check mb-3" style="padding-left:1.6rem">
                    <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                    <label asp-for="IsAvailable" class="form-check-label">Available</label>
                </div>
            </div>

            <div class="card-footer text-center bg-light">
                <button type="submit" class="btn btn-lg btn-primary px-5">
                    <i class="fas fa-save"></i> Update Item
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('ImageFile')?.addEventListener('change', function(e) {
            const file = e.target.files[0];
            const preview = document.getElementById('imagePreview');
            const img = document.getElementById('previewImg');
            if (file) {
                const reader = new FileReader();
                reader.onload = e => { img.src = e.target.result; preview.style.display = 'block'; };
                reader.readAsDataURL(file);
            }
        });
    </script>
}